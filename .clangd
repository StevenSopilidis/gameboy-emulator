CompileFlags:
  Add:
    - -Wall
    - -Wextra
    - -Wpedantic
    - -Wshadow
    - -Wconversion
    - -Wsign-conversion
    - -Wnull-dereference
    - -Wdouble-promotion
    - -std=c++20

  Remove:
    - -Werror

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - bugprone-*
      - performance-*
      - readability-*
      - modernize-*
    Remove:
      - modernize-use-trailing-return-type
      - readability-magic-numbers

Index:
  Background: Build

Completion:
  AllScopes: true
  DetailedLabel: true

Hover:
  ShowAKA: true

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Formatting:
  Style: file
